# =============================================================================
# GOOGLE GEMINI AI - REQUIRED
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
# This is required for AI Mentor and Repository Scanner features
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# These values match docker-compose.yml - only change if you modify docker-compose
DB_HOST=db
DB_PORT=3306
DB_USERNAME=mockgen_user
DB_PASSWORD=mockgen_password
DB_DATABASE=mockgen_db

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
# These values match docker-compose.yml - only change if you modify docker-compose
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=3000
